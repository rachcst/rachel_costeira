---
interface Props {
  title: string;
  url: string;
  date: string | Date;
  description?: string;
  tags?: string[];
};

const { title, url, date, description, tags } = Astro.props;
import { formatDate } from  "../js/utils.js"

---
<div class="postcard">
  <div class="postcardHeader">
    <p class="postDate">{formatDate(date)}</p>
  </div>
  <div class="postcardBody">
    <h1 class="postTitle">{title}</h1>
    <p class="postDescription">{description}</p>
  </div>
  <div class="postcardFooter">
    <p class="postcardTags">
      {(tags || []).map((tag) => (
        <a id="tag" href={`/tags/${tag}`}>#{tag}</a>
      ))}
    </p>
  </div>
</div>

